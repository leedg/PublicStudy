flowchart TD
    classDef api    fill:#1A237E,color:#fff,stroke:#1A237E,font-weight:bold
    classDef policy fill:#FFF3E0,color:#BF360C,stroke:#EF6C00
    classDef mutex  fill:#E3F2FD,color:#0D47A1,stroke:#1565C0
    classDef lf     fill:#E8F5E9,color:#1B5E20,stroke:#2E7D32
    classDef cv     fill:#F3E5F5,color:#4527A0,stroke:#512DA8

    API["ExecutionQueue&lt;T&gt;\nPush / TryPush / Pop / TryPop / Shutdown"]:::api

    BP{"BackpressurePolicy"}:::policy
    BK{"QueueBackend"}:::policy

    M["Mutex 백엔드\n──────────────\nstd::queue&lt;T&gt;\n+ mMutexQueueMutex\n크기: 무제한 가능"]:::mutex

    LF["Lock-Free 백엔드\n──────────────\nBoundedLockFreeQueue&lt;T&gt;\n링 버퍼 (2^N 크기 필수)\nCAS 기반 무락 enqueue/dequeue"]:::lf

    CV1["mNotEmptyCV\n(mWaitMutex 보호)\nPop 대기"]:::cv
    CV2["mNotFullMutexCV\n(mMutexQueueMutex 보호)\nBlock Push 대기"]:::cv
    CV3["mNotFullLFCV\n(mWaitMutex 보호)\nBlock Push 대기 (LF)"]:::cv

    API --> BP
    BP -->|"RejectNewest\n(큐 가득 시 false 반환)"| BK
    BP -->|"Block\n(큐 가득 시 CV 대기)"| BK
    BK -->|"Mutex"| M
    BK -->|"LockFree"| LF
    M  --> CV1
    M  --> CV2
    LF --> CV1
    LF --> CV3
