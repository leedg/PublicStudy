<?xml version='1.0' encoding='utf-8'?>
<mxfile host="app.diagrams.net">
  <diagram name="DB Reconnect Sequence">
    <mxGraphModel dx="1422" dy="794" grid="1" gridSize="10" page="1" pageWidth="1920" pageHeight="1080">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ── Participants ── -->
        <mxCell id="p0" value="DBRecvLoop" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="150" height="40" as="geometry" />
        </mxCell>
        <mxCell id="p1" value="TestServer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="260" y="40" width="150" height="40" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="DBReconnectLoop" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="480" y="40" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="p3" value="DBServer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="720" y="40" width="150" height="40" as="geometry" />
        </mxCell>

        <!-- ── Messages ── -->
        <!-- 1. DBRecvLoop → TestServer: recv failed (dashed) -->
        <mxCell id="e0" value="1. recv failed / connection closed" style="endArrow=block;dashed=1;html=1;strokeWidth=2;" edge="1" parent="1" source="p0" target="p1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="115" y="130"/><mxPoint x="335" y="130"/></Array></mxGeometry>
        </mxCell>
        <!-- 2. TestServer → DBReconnectLoop: start reconnect thread -->
        <mxCell id="e1" value="2. start reconnect thread" style="endArrow=block;html=1;strokeWidth=2;" edge="1" parent="1" source="p1" target="p2">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="335" y="180"/><mxPoint x="560" y="180"/></Array></mxGeometry>
        </mxCell>

        <!-- loop box -->
        <mxCell id="loopBox" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#9673a6;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="430" y="200" width="470" height="560" as="geometry" />
        </mxCell>
        <mxCell id="loopLabel" value="loop [while server running &amp; DB disconnected]" style="text;html=1;align=left;verticalAlign=top;fontStyle=2;strokeColor=none;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="430" y="200" width="400" height="24" as="geometry" />
        </mxCell>

        <!-- 3. DBReconnectLoop self: wait(delayMs) with condition_variable -->
        <mxCell id="e2" value="3. wait(delayMs) with condition_variable" style="endArrow=block;html=1;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="260" as="sourcePoint"/>
            <mxPoint x="560" y="310" as="targetPoint"/>
            <Array as="points"><mxPoint x="620" y="260"/><mxPoint x="620" y="310"/></Array>
          </mxGeometry>
        </mxCell>
        <!-- 4. DBReconnectLoop → DBServer: ConnectToDBServer -->
        <mxCell id="e3" value="4. ConnectToDBServer(host, port)" style="endArrow=block;html=1;strokeWidth=2;" edge="1" parent="1" source="p2" target="p3">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="560" y="360"/><mxPoint x="795" y="360"/></Array></mxGeometry>
        </mxCell>

        <!-- alt success box -->
        <mxCell id="altBox" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#82b366;strokeWidth=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="440" y="390" width="450" height="350" as="geometry" />
        </mxCell>
        <mxCell id="altLabel" value="alt" style="text;html=1;align=left;fontStyle=1;strokeColor=none;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="440" y="390" width="40" height="24" as="geometry" />
        </mxCell>
        <mxCell id="altSuccess" value="[success]" style="text;html=1;align=center;fontStyle=2;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="550" y="390" width="200" height="20" as="geometry" />
        </mxCell>

        <!-- 5. DBServer → DBReconnectLoop: connected (return) -->
        <mxCell id="e4" value="5. connected" style="endArrow=block;dashed=1;html=1;strokeWidth=2;" edge="1" parent="1" source="p3" target="p2">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="795" y="430"/><mxPoint x="560" y="430"/></Array></mxGeometry>
        </mxCell>
        <!-- 6. DBReconnectLoop → TestServer: reconnect success (return) -->
        <mxCell id="e5" value="6. reconnect success" style="endArrow=block;dashed=1;html=1;strokeWidth=2;" edge="1" parent="1" source="p2" target="p1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="560" y="480"/><mxPoint x="335" y="480"/></Array></mxGeometry>
        </mxCell>

        <!-- alt WSAECONNREFUSED divider -->
        <mxCell id="altRefused" value="[WSAECONNREFUSED]" style="text;html=1;align=center;fontStyle=2;strokeColor=#82b366;fillColor=none;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="440" y="520" width="450" height="20" as="geometry" />
        </mxCell>
        <!-- 7. self: delay = 1000ms fixed -->
        <mxCell id="e6" value="7. delay = 1000ms fixed" style="endArrow=block;html=1;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="560" as="sourcePoint"/>
            <mxPoint x="560" y="610" as="targetPoint"/>
            <Array as="points"><mxPoint x="620" y="560"/><mxPoint x="620" y="610"/></Array>
          </mxGeometry>
        </mxCell>

        <!-- alt other socket error divider -->
        <mxCell id="altOther" value="[other socket error]" style="text;html=1;align=center;fontStyle=2;strokeColor=#82b366;fillColor=none;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="440" y="640" width="450" height="20" as="geometry" />
        </mxCell>
        <!-- 8. self: exponential backoff -->
        <mxCell id="e7" value="8. exponential backoff, max 30000ms" style="endArrow=block;html=1;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="680" as="sourcePoint"/>
            <mxPoint x="560" y="730" as="targetPoint"/>
            <Array as="points"><mxPoint x="630" y="680"/><mxPoint x="630" y="730"/></Array>
          </mxGeometry>
        </mxCell>

        <!-- ── Note ── -->
        <mxCell id="note" value="condition_variable: shutdown signal wakes reconnect loop immediately without waiting for delay timeout" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="800" width="500" height="50" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
