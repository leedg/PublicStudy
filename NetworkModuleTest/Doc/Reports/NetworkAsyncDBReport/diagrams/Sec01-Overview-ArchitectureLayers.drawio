<?xml version="1.0" encoding="UTF-8"?>
<mxGraphModel grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1200" pageHeight="960" math="0" shadow="0">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <!-- Title bar -->
    <mxCell id="2" value="ServerEngine  Architecture Overview" style="fillColor=#1E3A5C;strokeColor=none;fontColor=#FFFFFF;fontSize=15;fontStyle=1;html=1;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="0" y="0" width="1200" height="52" as="geometry"/></mxCell>
    <!-- C-Style: Top analogy box -->
    <mxCell id="c_arch_analogy" value="&lt;b&gt;🏢 건물 층 구조로 이해하기&lt;/b&gt;&lt;br/&gt;1층 (INetworkEngine): 건물 입구 — 누구나 같은 문으로 들어옵니다&lt;br/&gt;2층 (BaseNetworkEngine): 관리실 — 공통 업무(세션 등록, 통계)를 처리합니다&lt;br/&gt;3층 (Platform Engines): 층마다 다른 설비 — Windows/Linux/macOS 각자 방식이 다릅니다&lt;br/&gt;지하 (I/O Provider): 전기/수도 설비 — 실제 데이터를 읽고 쓰는 저수준 장치입니다" style="rounded=1;arcSize=5;whiteSpace=wrap;html=1;fillColor=#FEFCBF;strokeColor=#ECC94B;strokeWidth=2;fontColor=#744210;fontSize=11;verticalAlign=middle;align=left;spacingLeft=14;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="0" y="52" width="1200" height="72" as="geometry"/></mxCell>
    <!-- Client box -->
    <mxCell id="3" value="&lt;b&gt;&lt;font style=&quot;font-size:13px;&quot;&gt;Client App  /  TestClient&lt;/font&gt;&lt;/b&gt;" style="rounded=1;arcSize=30;whiteSpace=wrap;html=1;fillColor=#718096;strokeColor=none;strokeWidth=0;fontColor=#FFFFFF;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="390" y="138" width="420" height="52" as="geometry"/></mxCell>
    <!-- Network Engine Layer container -->
    <mxCell id="4" value="Network Engine Layer" style="rounded=1;arcSize=6;whiteSpace=wrap;html=1;fillColor=#EBF5FF;strokeColor=#2E6DA4;strokeWidth=2;fontColor=#2E6DA4;fontStyle=1;fontSize=11;verticalAlign=top;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="20" y="207" width="1160" height="345" as="geometry"/></mxCell>
    <!-- INetworkEngine interface -->
    <mxCell id="5" value="&lt;b&gt;&lt;font style=&quot;font-size:12px;&quot;&gt;&lt;&lt;interface&gt;&gt;  INetworkEngine&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Initialize  /  Start  /  Stop  /  SendData  /  CloseConnection&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;모든 플랫폼이 구현해야 하는 공통 계약&lt;/font&gt;" style="rounded=1;arcSize=34;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1E3A5C;strokeWidth=2;fontColor=#1E3A5C;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="100" y="230" width="1000" height="52" as="geometry"/></mxCell>
    <!-- BaseNetworkEngine -->
    <mxCell id="6" value="&lt;b&gt;&lt;font style=&quot;font-size:13px;&quot;&gt;BaseNetworkEngine&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;세션 관리  ·  이벤트 콜백  ·  통계 집계  ·  공통 Recv/Send 처리&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;공통 업무를 한 곳에서 — 3개 플랫폼이 각자 짤 필요 없음&lt;/font&gt;" style="rounded=1;arcSize=25;whiteSpace=wrap;html=1;fillColor=#1E3A5C;strokeColor=none;strokeWidth=0;fontColor=#FFFFFF;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="230" y="300" width="740" height="68" as="geometry"/></mxCell>
    <!-- Platform engine boxes -->
    <mxCell id="7" value="&lt;b&gt;&lt;font style=&quot;font-size:12px;&quot;&gt;WindowsNetworkEngine&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;RIO  →  IOCP (fallback)&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;Windows 전용 고성능 I/O&lt;/font&gt;" style="rounded=1;arcSize=13;whiteSpace=wrap;html=1;fillColor=#2E6DA4;strokeColor=none;strokeWidth=0;fontColor=#FFFFFF;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="65" y="416" width="290" height="122" as="geometry"/></mxCell>
    <mxCell id="8" value="&lt;b&gt;&lt;font style=&quot;font-size:12px;&quot;&gt;LinuxNetworkEngine&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;io_uring  →  epoll (fallback)&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;Linux 전용 고성능 I/O&lt;/font&gt;" style="rounded=1;arcSize=13;whiteSpace=wrap;html=1;fillColor=#2E6DA4;strokeColor=none;strokeWidth=0;fontColor=#FFFFFF;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="440" y="416" width="290" height="122" as="geometry"/></mxCell>
    <mxCell id="9" value="&lt;b&gt;&lt;font style=&quot;font-size:12px;&quot;&gt;macOSNetworkEngine&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;kqueue&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;macOS 전용 I/O&lt;/font&gt;" style="rounded=1;arcSize=13;whiteSpace=wrap;html=1;fillColor=#2E6DA4;strokeColor=none;strokeWidth=0;fontColor=#FFFFFF;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="820" y="416" width="280" height="122" as="geometry"/></mxCell>
    <!-- I/O Provider Layer container -->
    <mxCell id="10" value="I/O Provider Layer" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#E8F4FD;strokeColor=#4A90C4;strokeWidth=2;fontColor=#4A90C4;fontStyle=1;fontSize=11;verticalAlign=top;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="20" y="572" width="1160" height="240" as="geometry"/></mxCell>
    <mxCell id="11" value="&lt;b&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;RIO  /  IOCP&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;Windows Non-Paged Pool&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;slab buffer pool&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;커널이 버퍼 직접 관리&lt;/font&gt;" style="rounded=1;arcSize=17;whiteSpace=wrap;html=1;fillColor=#4A90C4;strokeColor=none;strokeWidth=0;fontColor=#FFFFFF;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="614" width="268" height="100" as="geometry"/></mxCell>
    <mxCell id="12" value="&lt;b&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;io_uring  /  epoll&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;Linux fixed buffer&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;io_uring_register_buffers&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;커널과 공유 메모리 링&lt;/font&gt;" style="rounded=1;arcSize=17;whiteSpace=wrap;html=1;fillColor=#4A90C4;strokeColor=none;strokeWidth=0;fontColor=#FFFFFF;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="358" y="614" width="268" height="100" as="geometry"/></mxCell>
    <mxCell id="13" value="&lt;b&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;epoll  /  kqueue&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;Linux · macOS&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;standard I/O&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;범용 비동기 I/O&lt;/font&gt;" style="rounded=1;arcSize=17;whiteSpace=wrap;html=1;fillColor=#4A90C4;strokeColor=none;strokeWidth=0;fontColor=#FFFFFF;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="676" y="614" width="260" height="100" as="geometry"/></mxCell>
    <mxCell id="14" value="&lt;b&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;StandardBufferPool&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;aligned_malloc&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;lock-free freelist&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;범용 버퍼 풀&lt;/font&gt;" style="rounded=1;arcSize=17;whiteSpace=wrap;html=1;fillColor=#4A90C4;strokeColor=none;strokeWidth=0;fontColor=#FFFFFF;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="986" y="614" width="194" height="100" as="geometry"/></mxCell>
    <!-- Arrows (original, adjusted y for shifted layout) -->
    <mxCell id="15" value="① 클라이언트가 연결 시도" style="endArrow=block;endFill=1;strokeColor=#4A5568;strokeWidth=2;html=1;fontColor=#4A5568;fontSize=11;" edge="1" source="3" target="5" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="16" value="" style="endArrow=block;endFill=1;strokeColor=#4A5568;strokeWidth=2;html=1;" edge="1" source="5" target="6" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="17" value="" style="endArrow=block;endFill=1;strokeColor=#4A5568;strokeWidth=2;html=1;" edge="1" source="6" target="7" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="18" value="" style="endArrow=block;endFill=1;strokeColor=#4A5568;strokeWidth=2;html=1;" edge="1" source="6" target="8" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="19" value="" style="endArrow=block;endFill=1;strokeColor=#4A5568;strokeWidth=2;html=1;" edge="1" source="6" target="9" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="20" value="" style="endArrow=block;endFill=1;strokeColor=#4A5568;strokeWidth=2;html=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="210" y="538" as="sourcePoint"/><mxPoint x="174" y="614" as="targetPoint"/></mxGeometry></mxCell>
    <mxCell id="21" value="" style="endArrow=block;endFill=1;strokeColor=#4A5568;strokeWidth=2;html=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="585" y="538" as="sourcePoint"/><mxPoint x="492" y="614" as="targetPoint"/></mxGeometry></mxCell>
