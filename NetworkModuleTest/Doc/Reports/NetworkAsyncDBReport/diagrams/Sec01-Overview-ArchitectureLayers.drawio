    <!-- C-Style: "왜?" callout boxes -->
    <mxCell id="c_arch_why1" value="&lt;i&gt;왜 인터페이스?&lt;/i&gt;&lt;br/&gt;플랫폼이 달라져도 게임 서버 코드를 바꾸지 않아도 됩니다" style="shape=callout;whiteSpace=wrap;html=1;fillColor=#FEFCBF;strokeColor=#ECC94B;fontSize=10;fontStyle=2;fontColor=#744210;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="20" y="224" width="72" height="60" as="geometry"/></mxCell>
    <mxCell id="c_arch_why2" value="&lt;i&gt;왜 공통 엔진?&lt;/i&gt;&lt;br/&gt;세션 관리, 통계 같은 코드를 3번 짜지 않기 위해" style="shape=callout;whiteSpace=wrap;html=1;fillColor=#FEFCBF;strokeColor=#ECC94B;fontSize=10;fontStyle=2;fontColor=#744210;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="20" y="300" width="200" height="54" as="geometry"/></mxCell>
    <mxCell id="c_arch_why3" value="&lt;i&gt;왜 3개?&lt;/i&gt;&lt;br/&gt;Windows/Linux/macOS 각각 소켓 방식이 완전히 다릅니다" style="shape=callout;whiteSpace=wrap;html=1;fillColor=#FEFCBF;strokeColor=#ECC94B;fontSize=10;fontStyle=2;fontColor=#744210;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="20" y="370" width="200" height="44" as="geometry"/></mxCell>
    <!-- Summary box (B-style green bottom box, C-style) -->
    <mxCell id="c_arch_summary" value="✅ 핵심 포인트: &quot;어떤 OS에서 실행해도 게임 서버 코드는 바뀌지 않는다&quot; — 인터페이스와 계층 분리 덕분입니다." style="rounded=1;arcSize=5;whiteSpace=wrap;html=1;fillColor=#F0FFF4;strokeColor=#68D391;strokeWidth=2;fontColor=#276749;fontStyle=1;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="20" y="826" width="1160" height="48" as="geometry"/></mxCell>
