<?xml version='1.0' encoding='utf-8'?>
<mxfile host="app.diagrams.net">
  <diagram name="ExecutionQueue — Mutex Backend (simplified)">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" page="1" pageWidth="1920" pageHeight="1080">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="ExecutionQueue&lt;T&gt;  —  Mutex Backend (simplified)"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1f3d63;strokeColor=#1f3d63;fontColor=#ffffff;fontSize=26;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="120" y="40" width="1200" height="55" as="geometry" />
        </mxCell>

        <!-- Members column -->
        <mxCell id="mem_box" value="Members"
          style="swimlane;fontStyle=1;startSize=34;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=16;"
          vertex="1" parent="1">
          <mxGeometry x="120" y="130" width="400" height="340" as="geometry" />
        </mxCell>
        <mxCell id="mem1" value="std::queue&lt;T&gt;  mQueue"
          style="text;align=left;spacingLeft=10;fontSize=15;" vertex="1" parent="mem_box">
          <mxGeometry x="0" y="34" width="400" height="34" as="geometry" />
        </mxCell>
        <mxCell id="mem2" value="std::mutex  mMutex"
          style="text;align=left;spacingLeft=10;fontSize=15;" vertex="1" parent="mem_box">
          <mxGeometry x="0" y="72" width="400" height="34" as="geometry" />
        </mxCell>
        <mxCell id="mem3" value="condition_variable  mNotEmptyCV"
          style="text;align=left;spacingLeft=10;fontSize=15;" vertex="1" parent="mem_box">
          <mxGeometry x="0" y="110" width="400" height="34" as="geometry" />
        </mxCell>
        <mxCell id="mem4" value="condition_variable  mNotFullCV"
          style="text;align=left;spacingLeft=10;fontSize=15;" vertex="1" parent="mem_box">
          <mxGeometry x="0" y="148" width="400" height="34" as="geometry" />
        </mxCell>
        <mxCell id="mem5" value="atomic&lt;bool&gt;  mShutdown"
          style="text;align=left;spacingLeft=10;fontSize=15;" vertex="1" parent="mem_box">
          <mxGeometry x="0" y="186" width="400" height="34" as="geometry" />
        </mxCell>
        <mxCell id="mem6" value="atomic&lt;size_t&gt;  mSize"
          style="text;align=left;spacingLeft=10;fontSize=15;" vertex="1" parent="mem_box">
          <mxGeometry x="0" y="224" width="400" height="34" as="geometry" />
        </mxCell>
        <mxCell id="mem7" value="size_t  mCapacity  (0 = unbounded)"
          style="text;align=left;spacingLeft=10;fontSize=15;fontColor=#666666;" vertex="1" parent="mem_box">
          <mxGeometry x="0" y="262" width="400" height="34" as="geometry" />
        </mxCell>

        <!-- Push flow -->
        <mxCell id="push_box" value="TryPushImpl / PushBlocking (producer)"
          style="swimlane;fontStyle=1;startSize=34;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;"
          vertex="1" parent="1">
          <mxGeometry x="580" y="130" width="660" height="340" as="geometry" />
        </mxCell>
        <mxCell id="push1" value="lock_guard(mMutex)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;"
          vertex="1" parent="push_box">
          <mxGeometry x="20" y="50" width="620" height="46" as="geometry" />
        </mxCell>
        <mxCell id="push2" value="capacity check → mQueue.push(std::move(value))"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;"
          vertex="1" parent="push_box">
          <mxGeometry x="20" y="112" width="620" height="46" as="geometry" />
        </mxCell>
        <mxCell id="push3" value="mSize.fetch_add(1, release)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;"
          vertex="1" parent="push_box">
          <mxGeometry x="20" y="174" width="620" height="46" as="geometry" />
        </mxCell>
        <mxCell id="push4" value="unlock  →  mNotEmptyCV.notify_one()"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#82b366;strokeColor=#5a8a40;fontColor=#ffffff;fontSize=15;fontStyle=1;"
          vertex="1" parent="push_box">
          <mxGeometry x="20" y="236" width="620" height="46" as="geometry" />
        </mxCell>

        <!-- Pop flow -->
        <mxCell id="pop_box" value="PopWait (consumer)"
          style="swimlane;fontStyle=1;startSize=34;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=15;"
          vertex="1" parent="1">
          <mxGeometry x="580" y="510" width="660" height="380" as="geometry" />
        </mxCell>
        <mxCell id="pop1" value="unique_lock(mMutex)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=15;"
          vertex="1" parent="pop_box">
          <mxGeometry x="20" y="50" width="620" height="46" as="geometry" />
        </mxCell>
        <mxCell id="pop2" value="mNotEmptyCV.wait_until(lock, deadline, []{!mQueue.empty()})"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=15;"
          vertex="1" parent="pop_box">
          <mxGeometry x="20" y="110" width="620" height="46" as="geometry" />
        </mxCell>
        <mxCell id="pop3" value="mQueue.front()  →  mQueue.pop()  →  mSize.fetch_sub(1)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=15;"
          vertex="1" parent="pop_box">
          <mxGeometry x="20" y="170" width="620" height="46" as="geometry" />
        </mxCell>
        <mxCell id="pop4" value="unlock  →  mNotFullCV.notify_one()"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d79b00;strokeColor=#a05900;fontColor=#ffffff;fontSize=15;fontStyle=1;"
          vertex="1" parent="pop_box">
          <mxGeometry x="20" y="230" width="620" height="46" as="geometry" />
        </mxCell>
        <mxCell id="pop5" value="★ same mMutex in push + pop  →  missed-notification impossible"
          style="text;html=1;align=center;fontStyle=2;fontSize=14;fontColor=#a05900;"
          vertex="1" parent="pop_box">
          <mxGeometry x="20" y="300" width="620" height="34" as="geometry" />
        </mxCell>

        <!-- Backpressure -->
        <mxCell id="bp_box" value="BackpressurePolicy"
          style="swimlane;fontStyle=1;startSize=30;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;"
          vertex="1" parent="1">
          <mxGeometry x="120" y="510" width="400" height="140" as="geometry" />
        </mxCell>
        <mxCell id="bp1" value="RejectNewest → TryPush (non-blocking)"
          style="text;align=left;spacingLeft=10;fontSize=14;" vertex="1" parent="bp_box">
          <mxGeometry x="0" y="34" width="400" height="30" as="geometry" />
        </mxCell>
        <mxCell id="bp2" value="Block → PushBlocking (waits mNotFullCV)"
          style="text;align=left;spacingLeft=10;fontSize=14;" vertex="1" parent="bp_box">
          <mxGeometry x="0" y="68" width="400" height="30" as="geometry" />
        </mxCell>
        <mxCell id="bp3" value="Shutdown: notify_all → drain remaining items"
          style="text;align=left;spacingLeft=10;fontSize=14;fontColor=#b85450;" vertex="1" parent="bp_box">
          <mxGeometry x="0" y="102" width="400" height="30" as="geometry" />
        </mxCell>

        <!-- Arrow push→pop (showing queue between them) -->
        <mxCell id="arr1" value="enqueue" style="endArrow=block;endFill=1;html=1;strokeWidth=3;strokeColor=#82b366;fontSize=13;"
          edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="320" y="310" as="sourcePoint" />
            <mxPoint x="580" y="310" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="arr2" value="dequeue" style="endArrow=block;endFill=1;html=1;strokeWidth=3;strokeColor=#d79b00;fontSize=13;"
          edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="320" y="380" as="sourcePoint" />
            <mxPoint x="580" y="640" as="targetPoint" />
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
