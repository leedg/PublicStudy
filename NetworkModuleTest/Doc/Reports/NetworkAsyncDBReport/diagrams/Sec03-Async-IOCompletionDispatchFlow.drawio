    <mxCell id="39" value="동일 세션의 모든 작업은 항상 같은 Logic Worker로 전달  →  Session 단위 FIFO 보장  →  recv 처리에 Lock 불필요" style="rounded=1;arcSize=5;whiteSpace=wrap;html=1;fillColor=#FEFCBF;strokeColor=#ECC94B;strokeWidth=1.5;fontColor=#744210;fontStyle=0;fontSize=11;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="260" y="128" width="808" height="44" as="geometry"/></mxCell>
