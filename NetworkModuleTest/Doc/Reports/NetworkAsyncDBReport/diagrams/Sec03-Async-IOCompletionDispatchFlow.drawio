    <!-- Title bar -->
    <mxCell id="2" value="Async Thread Model  —  Dispatch Flow" style="fillColor=#1E3A5C;strokeColor=none;fontColor=#FFFFFF;fontSize=15;fontStyle=1;html=1;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="0" y="0" width="1140" height="52" as="geometry"/></mxCell>
    <!-- C-Style: Top analogy box -->
    <mxCell id="c_disp_analogy" value="&lt;b&gt;🏥 병원 접수 시스템으로 이해하기&lt;/b&gt;&lt;br/&gt;IO Workers = 접수 창구 (환자를 받아 번호표 발급) | KeyedDispatcher = 배정 담당자 (환자 번호 % 진료실 수 → 담당 의사 결정)&lt;br/&gt;Logic Workers = 진료실 의사 (실제 처리) | DBTaskQueue = 처방전 접수함 (처방은 약국에 비동기로 전달)" style="rounded=1;arcSize=5;whiteSpace=wrap;html=1;fillColor=#FEFCBF;strokeColor=#ECC94B;strokeWidth=2;fontColor=#744210;fontSize=11;verticalAlign=middle;align=left;spacingLeft=14;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="0" y="52" width="1140" height="66" as="geometry"/></mxCell>
