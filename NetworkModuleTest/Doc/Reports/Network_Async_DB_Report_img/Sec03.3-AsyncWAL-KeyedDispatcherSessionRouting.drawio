    <!-- KeyedDispatcher core box with formula callout inside -->
    <mxCell id="17" value="&lt;b&gt;&lt;font style=&quot;font-size:12px;&quot;&gt;KeyedDispatcher&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Dispatch(key, task)&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;worker_idx = key % worker_count (= key % 3)&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;계산대 배정 담당자&lt;/font&gt;" style="rounded=1;arcSize=9;whiteSpace=wrap;html=1;fillColor=#1E3A5C;strokeColor=none;strokeWidth=0;fontColor=#FFFFFF;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="310" y="256" width="246" height="140" as="geometry"/></mxCell>
    <!-- Formula box (B-style) with C-style visual callout -->
    <mxCell id="18" value="&lt;b&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;worker_idx = session_id % 3&lt;/font&gt;&lt;/b&gt;" style="rounded=1;arcSize=42;whiteSpace=wrap;html=1;fillColor=#EBF8FF;strokeColor=#2E6DA4;strokeWidth=1.5;fontColor=#1E3A5C;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="318" y="316" width="230" height="38" as="geometry"/></mxCell>
    <!-- C-Style: visual callout at formula box -->
    <mxCell id="c_keyed_formula" value="세션 ID를 워커 수(3)로 나눈 나머지&lt;br/&gt;= 담당 워커 번호&lt;br/&gt;예) ID 7 → 7 % 3 = 1 → Worker 1" style="shape=callout;whiteSpace=wrap;html=1;fillColor=#FEFCBF;strokeColor=#ECC94B;strokeWidth=1.5;fontSize=10;fontColor=#744210;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="310" y="406" width="246" height="66" as="geometry"/></mxCell>
    <!-- Worker boxes (shifted down) -->
    <mxCell id="19" value="&lt;b&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;Worker  0&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;1번 계산대&lt;/font&gt;" style="rounded=1;arcSize=23;whiteSpace=wrap;html=1;fillColor=#2E6DA4;strokeColor=none;strokeWidth=0;fontColor=#FFFFFF;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="640" y="476" width="204" height="58" as="geometry"/></mxCell>
    <mxCell id="20" value="&lt;b&gt;&lt;font style=&quot;font-size:9px;&quot;&gt; S0  →  S3  →  S6  →  …&lt;/font&gt;&lt;/b&gt;" style="rounded=1;arcSize=20;whiteSpace=wrap;html=1;fillColor=#EDF2F7;strokeColor=#2E6DA4;strokeWidth=1;fontColor=#4A5568;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="640" y="536" width="204" height="30" as="geometry"/></mxCell>
    <mxCell id="21" value="&lt;b&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;Worker  1&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;2번 계산대&lt;/font&gt;" style="rounded=1;arcSize=23;whiteSpace=wrap;html=1;fillColor=#4A90C4;strokeColor=none;strokeWidth=0;fontColor=#FFFFFF;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="640" y="356" width="204" height="58" as="geometry"/></mxCell>
