    <!-- Title bar -->
    <mxCell id="2" value="KeyedDispatcher  —  Session Affinity Routing" style="fillColor=#1E3A5C;strokeColor=none;fontColor=#FFFFFF;fontSize=15;fontStyle=1;html=1;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="0" y="0" width="1020" height="52" as="geometry"/></mxCell>
    <!-- C-Style: Top analogy box -->
    <mxCell id="c_keyed_analogy" value="&lt;b&gt;🏪 편의점 계산대 배정으로 이해하기&lt;/b&gt;&lt;br/&gt;세션 ID % 3 = 계산대 번호 | 손님 0, 3, 6 → 1번 계산대 (Worker 0) | 손님 1, 4 → 2번 계산대 (Worker 1) | 손님 2, 5 → 3번 계산대 (Worker 2)&lt;br/&gt;같은 손님은 항상 같은 계산대 → 재고 충돌 없음" style="rounded=1;arcSize=5;whiteSpace=wrap;html=1;fillColor=#FEFCBF;strokeColor=#ECC94B;strokeWidth=2;fontColor=#744210;fontSize=11;verticalAlign=middle;align=left;spacingLeft=14;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="0" y="52" width="1020" height="70" as="geometry"/></mxCell>
    <!-- Session boxes (shifted down by 70) -->
