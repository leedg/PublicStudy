    <!-- B-style info boxes updated with C-style simplified labels -->
    <mxCell id="35" value="FIFO 보장: 같은 Worker는 단일 스레드로 순차 실행&lt;br/&gt;Session::mRecvMutex 제거 가능  →  Lock-free 누적 버퍼 접근" style="rounded=1;arcSize=5;whiteSpace=wrap;html=1;fillColor=#C6F6D5;strokeColor=#48BB78;strokeWidth=1.5;fontColor=#276749;fontStyle=0;fontSize=11;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="24" y="122" width="440" height="52" as="geometry"/></mxCell>
    <mxCell id="36" value="종료 시 새 배정 차단 후 남은 작업 처리: 안전한 독점 잠금(exclusive_lock)&lt;br/&gt;Dispatch()의 동시 읽기 허용(shared_lock)과 안전하게 공존" style="rounded=1;arcSize=5;whiteSpace=wrap;html=1;fillColor=#FEFCBF;strokeColor=#ECC94B;strokeWidth=1.5;fontColor=#744210;fontStyle=0;fontSize=11;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="482" y="122" width="522" height="52" as="geometry"/></mxCell>
    <!-- Summary box -->
    <mxCell id="c_keyed_summary" value="✅ 핵심 포인트: 나머지 연산(%)으로 결정적 배정 → 같은 세션 데이터는 절대 동시에 접근되지 않습니다." style="rounded=1;arcSize=5;whiteSpace=wrap;html=1;fillColor=#F0FFF4;strokeColor=#68D391;strokeWidth=2;fontColor=#276749;fontStyle=1;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="24" y="696" width="980" height="44" as="geometry"/></mxCell>
