<mxfile host="app.diagrams.net"><diagram name="Async Thread Model - Separated Worker DBQueues"><mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" page="1" pageWidth="1920" pageHeight="1080"><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="title" value="Async Thread Model — Dispatch Flow" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#223d5b;strokeColor=#223d5b;fontColor=#ffffff;fontSize=24;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="25" y="18" width="1505" height="68" as="geometry" /></mxCell><mxCell id="note_top" value="동일 세션의 모든 작업은 항상 같은 Logic Worker로 전달 → Session 단위 FIFO 보장 → recv 처리에 Lock 불필요" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4e9a6;strokeColor=#d1b547;fontColor=#7a5c00;fontSize=13;" vertex="1" parent="1"><mxGeometry x="240" y="100" width="1110" height="58" as="geometry" /></mxCell><mxCell id="p_io" value="I/O Workers" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#f8eded;strokeColor=#ef8d8d;strokeWidth=2;fontColor=#c84a4a;fontSize=16;fontStyle=1;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" vertex="1" parent="1"><mxGeometry x="35" y="175" width="310" height="620" as="geometry" /></mxCell><mxCell id="p_key" value="KeyedDispatcher" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#e9f1fb;strokeColor=#4d86c5;strokeWidth=2;fontColor=#2f6aa5;fontSize=16;fontStyle=1;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" vertex="1" parent="1"><mxGeometry x="370" y="175" width="335" height="620" as="geometry" /></mxCell><mxCell id="p_logic" value="Logic Workers" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#eef7ef;strokeColor=#4a8d62;strokeWidth=2;fontColor=#2f7a48;fontSize=16;fontStyle=1;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" vertex="1" parent="1"><mxGeometry x="730" y="175" width="360" height="620" as="geometry" /></mxCell><mxCell id="p_db" value="DB Layer" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#fbf3e8;strokeColor=