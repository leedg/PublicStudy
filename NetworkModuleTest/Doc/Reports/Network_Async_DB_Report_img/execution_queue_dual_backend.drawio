st" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe7c2;strokeColor=#c97b00;" vertex="1" parent="1"><mxGeometry x="300" y="470" width="200" height="60" as="geometry" /></mxCell><mxCell id="m6" value="EnqueueBlock" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffd6d6;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="520" y="470" width="200" height="60" as="geometry" /></mxCell><mxCell id="m7" value="mSize: atomic&lt;size_t&gt;" style="text;html=1;strokeColor=none;fillColor=none;fontSize=16;" vertex="1" parent="1"><mxGeometry x="300" y="560" width="350" height="50" as="geometry" /></mxCell><mxCell id="l1" value="BoundedLockFreeQueue&lt;T&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d7a4d;strokeColor=#1c5b35;fontColor=#ffffff;fontSize=16;" vertex="1" parent="1"><mxGeometry x="1050" y="200" width="350" height="60" as="geometry" /></mxCell><mxCell id="l2" value="ring buffer (power-of-two)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b9e3c6;strokeColor=#2d7a4d;" vertex="1" parent="1"><mxGeometry x="1050" y="280" width="350" height="50" as="geometry" /></mxCell><mxCell id="s0" value="S0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a9ddb7;strokeColor=#2d7a4d;" vertex="1" parent="1"><mxGeometry x="1050" y="340" width="55" height="40" as="geometry" /></mxCell><mxCell id="s1" value="S1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a9ddb7;strokeColor=#2d7a4d;" vertex="1" parent="1"><mxGeometry x="1115" y="340" width="55" height="40" as="geometry" /></mxCell><mxCell id="s2" value="S2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a9ddb7;strokeColor=#2d7a4d;" vertex="1" parent="1"><mxGeometry x="1180" y="340" width="55" height="40" as="geometry" /></mxCell><mxCell id="s3" value="S3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a9ddb7;strokeColor=#2d7a4d;" vertex="1" parent="1"><mxGeometry x="1245" y="340" width="55" height="40" as="geometry" /></mxCell><mxCell id="s4" value="S4" style="rounded=1;whiteSpace=wrap;html=1