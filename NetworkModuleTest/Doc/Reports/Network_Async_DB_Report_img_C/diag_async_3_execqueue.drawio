<?xml version="1.0" encoding="UTF-8"?>
<mxGraphModel grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1060" pageHeight="820" math="0" shadow="0">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <!-- Title bar -->
    <mxCell id="2" value="ExecutionQueue&lt;T&gt;  —  Dual Backend" style="fillColor=#1E3A5C;strokeColor=none;fontColor=#FFFFFF;fontSize=15;fontStyle=1;html=1;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="0" y="0" width="1060" height="52" as="geometry"/></mxCell>
    <!-- C-Style: Top analogy box -->
    <mxCell id="c_eq_analogy" value="&lt;b&gt;🚻 두 가지 화장실 방식&lt;/b&gt;&lt;br/&gt;Mutex Backend = 열쇠 방식: 열쇠를 가진 사람만 입장, 나머지는 밖에서 대기&lt;br/&gt;Lock-Free Backend = 번호표 방식: 번호표로 순서만 정하고 동시에 준비 가능 (더 빠름)&lt;br/&gt;성능이 중요하면 Lock-Free, 안전하고 단순하면 Mutex" style="rounded=1;arcSize=5;whiteSpace=wrap;html=1;fillColor=#FEFCBF;strokeColor=#ECC94B;strokeWidth=2;fontColor=#744210;fontSize=11;verticalAlign=middle;align=left;spacingLeft=14;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="0" y="52" width="1060" height="72" as="geometry"/></mxCell>
    <!-- Divider -->
    <mxCell id="3" value="런타임 선택" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#718096;fontSize=11;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="440" y="124" width="180" height="22" as="geometry"/></mxCell>
    <mxCell id="c_divider" value="" style="rounded=1;arcSize=0;whiteSpace=wrap;html=1;fillColor=#CBD5E0;strokeColor=none;strokeWidth=0;fontColor=#FFFFFF;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="527" y="124" width="4" height="530" as="geometry"/></mxCell>
    <!-- Mutex Backend panel -->
    <mxCell id="5" value="Mutex Backend  (기본)&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;열쇠 방식 — 안전하고 단순&lt;/font&gt;" style="rounded=1;arcSize=5;whiteSpace=wrap;html=1;fillColor=#F7FAFC;strokeColor=#2E6DA4;strokeWidth=1.5;fontColor=#2E6DA4;fontStyle=1;fontSize=11;verticalAlign=top;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="18" y="124" width="504" height="530" as="geometry"/></mxCell>
    <!-- Mutex backend components (shifted down by 68px) -->
    <mxCell id="6" value="&lt;b&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;std::queue&lt;T&gt;&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;크기 제한 없음 (무제한)&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;대기 공간&lt;/font&gt;" style="rounded=1;arcSize=22;whiteSpace=wrap;html=1;fillColor=#2E6DA4;strokeColor=none;strokeWidth=0;fontColor=#FFFFFF;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="36" y="408" width="218" height="70" as="geometry"/></mxCell>
    <mxCell id="7" value="&lt;b&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;mMutexQueueMutex&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;std::mutex  lock / unlock&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;열쇠 자물쇠&lt;/font&gt;" style="rounded=1;arcSize=22;whiteSpace=wrap;html=1;fillColor=#4A90C4;strokeColor=none;strokeWidth=0;fontColor=#FFFFFF;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="278" y="408" width="232" height="70" as="geometry"/></mxCell>
    <mxCell id="8" value="&lt;b&gt;&lt;font style=&quot;font-size:10.5px;&quot;&gt;Enqueue:  lock  →  push  →  unlock  →  notify_one&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;열쇠 잠그고 넣고 알림&lt;/font&gt;" style="rounded=1;arcSize=33;whiteSpace=wrap;html=1;fillColor=#EBF8FF;strokeColor=#2E6DA4;strokeWidth=1;fontColor=#1E3A5C;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="36" y="342" width="474" height="56" as="geometry"/></mxCell>
    <mxCell id="9" value="&lt;b&gt;&lt;font style=&quot;font-size:10.5px;&quot;&gt;Dequeue:  lock  →  wait(CV)  →  pop  →  unlock&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;열쇠 잠그고 꺼내고 풀기&lt;/font&gt;" style="rounded=1;arcSize=33;whiteSpace=wrap;html=1;fillColor=#EBF8FF;strokeColor=#2E6DA4;strokeWidth=1;fontColor=#1E3A5C;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="36" y="286" width="474" height="56" as="geometry"/></mxCell>
    <mxCell id="10" value="Backpressure Policy" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#4A5568;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="260" y="268" width="180" height="20" as="geometry"/></mxCell>
    <mxCell id="11" value="&lt;b&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;RejectNewest&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;큐 가득 시 신규 작업 드롭&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;+ 경고 로그&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;자리 없으면 새 손님 거절&lt;/font&gt;" style="rounded=1;arcSize=21;whiteSpace=wrap;html=1;fillColor=#FEEBC8;strokeColor=#ED8936;strokeWidth=1;fontColor=#ED8936;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="36" y="196" width="222" height="64" as="geometry"/></mxCell>
    <mxCell id="12" value="&lt;b&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Block&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;Enqueue 호출자 블로킹&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;(condition_variable wait)&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;자리 날 때까지 기다림&lt;/font&gt;" style="rounded=1;arcSize=21;whiteSpace=wrap;html=1;fillColor=#FED7D7;strokeColor=#C53030;strokeWidth=1;fontColor=#C53030;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="280" y="196" width="230" height="64" as="geometry"/></mxCell>
    <mxCell id="13" value="&lt;b&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;mSize: atomic&lt;size_t&gt;  —  정확한 크기 (모니터링 + 백프레셔 판단)&lt;/font&gt;&lt;/b&gt;" style="rounded=1;arcSize=20;whiteSpace=wrap;html=1;fillColor=#EDF2F7;strokeColor=none;strokeWidth=0;fontColor=#4A5568;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="36" y="140" width="474" height="48" as="geometry"/></mxCell>
    <!-- Lock-Free Backend panel -->
    <mxCell id="14" value="Lock-Free Backend  (고성능)&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;번호표 방식 — 빠르지만 크기 제한&lt;/font&gt;" style="rounded=1;arcSize=5;whiteSpace=wrap;html=1;fillColor=#F0FFF4;strokeColor=#276749;strokeWidth=1.5;fontColor=#276749;fontStyle=1;fontSize=11;verticalAlign=top;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="538" y="124" width="504" height="530" as="geometry"/></mxCell>
    <!-- Lock-free components (shifted down) -->
    <mxCell id="15" value="&lt;b&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;BoundedLockFreeQueue&lt;T&gt;&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;링 버퍼  ·  크기: 2의 거듭제곱 (기본 1024)&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;번호표 대기열&lt;/font&gt;" style="rounded=1;arcSize=22;whiteSpace=wrap;html=1;fillColor=#276749;strokeColor=none;strokeWidth=0;fontColor=#FFFFFF;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="554" y="428" width="472" height="70" as="geometry"/></mxCell>
    <!-- Ring buffer slots -->
    <mxCell id="16" value="&lt;b&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;S0&lt;/font&gt;&lt;/b&gt;" style="rounded=1;arcSize=15;whiteSpace=wrap;html=1;fillColor=#C6F6D5;strokeColor=none;strokeWidth=0;fontColor=#276749;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="554" y="368" width="56" height="40" as="geometry"/></mxCell>
    <mxCell id="17" value="&lt;b&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;S1&lt;/font&gt;&lt;/b&gt;" style="rounded=1;arcSize=15;whiteSpace=wrap;html=1;fillColor=#9AE6B4;strokeColor=none;strokeWidth=0;fontColor=#276749;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="613" y="368" width="56" height="40" as="geometry"/></mxCell>
    <mxCell id="18" value="&lt;b&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;S2&lt;/font&gt;&lt;/b&gt;" style="rounded=1;arcSize=15;whiteSpace=wrap;html=1;fillColor=#68D391;strokeColor=none;strokeWidth=0;fontColor=#276749;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="672" y="368" width="56" height="40" as="geometry"/></mxCell>
    <mxCell id="19" value="&lt;b&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;S3&lt;/font&gt;&lt;/b&gt;" style="rounded=1;arcSize=15;whiteSpace=wrap;html=1;fillColor=#9AE6B4;strokeColor=none;strokeWidth=0;fontColor=#276749;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="731" y="368" width="56" height="40" as="geometry"/></mxCell>
    <mxCell id="20" value="&lt;b&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;S4&lt;/font&gt;&lt;/b&gt;" style="rounded=1;arcSize=15;whiteSpace=wrap;html=1;fillColor=#C6F6D5;strokeColor=none;strokeWidth=0;fontColor=#276749;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="790" y="368" width="56" height="40" as="geometry"/></mxCell>
    <mxCell id="21" value="&lt;b&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;S5&lt;/font&gt;&lt;/b&gt;" style="rounded=1;arcSize=15;whiteSpace=wrap;html=1;fillColor=#9AE6B4;strokeColor=none;strokeWidth=0;fontColor=#276749;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="849" y="368" width="56" height="40" as="geometry"/></mxCell>
    <mxCell id="22" value="&lt;b&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;S6&lt;/font&gt;&lt;/b&gt;" style="rounded=1;arcSize=15;whiteSpace=wrap;html=1;fillColor=#C6F6D5;strokeColor=none;strokeWidth=0;fontColor=#276749;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="908" y="368" width="56" height="40" as="geometry"/></mxCell>
    <mxCell id="23" value="&lt;b&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;S7&lt;/font&gt;&lt;/b&gt;" style="rounded=1;arcSize=15;whiteSpace=wrap;html=1;fillColor=#9AE6B4;strokeColor=none;strokeWidth=0;fontColor=#276749;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="967" y="368" width="56" height="40" as="geometry"/></mxCell>
    <mxCell id="24" value="← enqueuePos                              dequeuePos →" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#718096;fontSize=8;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="540" y="354" width="470" height="18" as="geometry"/></mxCell>
    <mxCell id="25" value="&lt;b&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Enqueue:  CAS(enqueuePos)  →  slot.sequence.store(release)&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;번호표 발급 후 슬롯 기록&lt;/font&gt;" style="rounded=1;arcSize=34;whiteSpace=wrap;html=1;fillColor=#F0FFF4;strokeColor=#276749;strokeWidth=1;fontColor=#1E3A5C;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="554" y="306" width="472" height="52" as="geometry"/></mxCell>
    <mxCell id="26" value="&lt;b&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Dequeue:  CAS(dequeuePos)  →  read  →  sequence.store(release)&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;번호표 소모 후 읽기&lt;/font&gt;" style="rounded=1;arcSize=34;whiteSpace=wrap;html=1;fillColor=#F0FFF4;strokeColor=#276749;strokeWidth=1;fontColor=#1E3A5C;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="554" y="252" width="472" height="52" as="geometry"/></mxCell>
    <!-- false sharing callout box (C-style) -->
    <mxCell id="27" value="&lt;b&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;alignas(64)&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;Cell 정렬  →  false sharing 방지&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;CPU 캐시 충돌 방지&lt;/font&gt;" style="rounded=1;arcSize=21;whiteSpace=wrap;html=1;fillColor=#C6F6D5;strokeColor=#276749;strokeWidth=1;fontColor=#276749;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="554" y="190" width="228" height="56" as="geometry"/></mxCell>
    <mxCell id="c_eq_falsesharing" value="&lt;b&gt;false sharing 방지&lt;/b&gt;&lt;br/&gt;다른 CPU 코어가 같은 캐시 라인을 건드리면&lt;br/&gt;실제로 다른 데이터인데도 서로 방해함&lt;br/&gt;→ 64바이트 정렬로 각 슬롯을 다른 캐시 라인에 배치" style="shape=callout;whiteSpace=wrap;html=1;fillColor=#C6F6D5;strokeColor=#276749;fontSize=10;fontColor=#276749;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="554" y="140" width="228" height="70" as="geometry"/></mxCell>
    <mxCell id="28" value="&lt;b&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;mSize: ±1 근사&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;fetch_add + TryEnqueue 비원자&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;→ 모니터링 전용&lt;/font&gt;" style="rounded=1;arcSize=21;whiteSpace=wrap;html=1;fillColor=#FEFCBF;strokeColor=#ECC94B;strokeWidth=1;fontColor=#744210;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="800" y="190" width="228" height="56" as="geometry"/></mxCell>
    <mxCell id="29" value="&lt;b&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Lock-Free Block 정책: 스핀 대기  →  condition_variable fallback&lt;/font&gt;&lt;/b&gt;" style="rounded=1;arcSize=25;whiteSpace=wrap;html=1;fillColor=#EDF2F7;strokeColor=none;strokeWidth=0;fontColor=#4A5568;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="554" y="140" width="472" height="40" as="geometry"/></mxCell>
    <!-- C-Style: CAS explanation callout box -->
    <mxCell id="c_eq_cas" value="&lt;b&gt;CAS (Compare-And-Swap) 이란?&lt;/b&gt;&lt;br/&gt;&quot;내가 기대하는 값일 때만 바꾼다&quot;&lt;br/&gt;실패하면 재시도 → 결국 누군가 성공&lt;br/&gt;= Lock 없이 순서 보장하는 마법" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#C6F6D5;strokeColor=#276749;strokeWidth=2;fontSize=10;fontColor=#276749;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="800" y="140" width="228" height="70" as="geometry"/></mxCell>
    <!-- Summary box -->
    <mxCell id="c_eq_summary" value="✅ 핵심 포인트: 같은 큐를 Mutex/Lock-Free 중 런타임에 선택 가능. Lock-Free는 빠르지만 크기 제한 있음 (기본 1024)." style="rounded=1;arcSize=5;whiteSpace=wrap;html=1;fillColor=#F0FFF4;strokeColor=#68D391;strokeWidth=2;fontColor=#276749;fontStyle=1;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="18" y="666" width="1024" height="44" as="geometry"/></mxCell>
  </root>
</mxGraphModel>
