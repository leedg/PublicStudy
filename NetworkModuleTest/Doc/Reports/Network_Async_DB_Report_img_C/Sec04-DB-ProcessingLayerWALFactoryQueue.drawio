<mxGraphModel dx="1328" dy="1936" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1260" pageHeight="960" math="0" shadow="0">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <!-- Title bar -->
    <mxCell id="2" value="DB Processing  —  DBTaskQueue  &amp;  IDatabase Abstraction Layer" style="fillColor=#1E3A5C;strokeColor=none;fontColor=#FFFFFF;fontSize=15;fontStyle=1;html=1;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="0" y="0" width="1260" height="52" as="geometry"/></mxCell>
    <!-- C-Style: Top analogy box -->
    <mxCell id="c_db_analogy" value="&lt;b&gt;🍽️ 식당 주문 시스템으로 이해하기&lt;/b&gt;&lt;br/&gt;ClientSession (웨이터): 손님 주문을 받아 주문서에 적고 즉시 다음 손님에게 | DBTaskQueue (주문 대기열): 주방에 전달될 주문이 쌓이는 곳&lt;br/&gt;WAL (영수증): 주문서를 먼저 발행해 두고 → 나중에 처리됐다고 체크 | DB Worker (주방): 주문을 순서대로 처리 | SQLite/ODBC (조리 방식): 메뉴에 따라 조리법이 다를 수 있음" style="rounded=1;arcSize=5;whiteSpace=wrap;html=1;fillColor=#FEFCBF;strokeColor=#ECC94B;strokeWidth=2;fontColor=#744210;fontSize=11;verticalAlign=middle;align=left;spacingLeft=14;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="0" y="52" width="1260" height="72" as="geometry"/></mxCell>
    <!-- Session Events panel (shifted down 72px) -->
    <mxCell id="3" value="Session Events&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;웨이터 — 논블로킹 위임&lt;/font&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#F0FFF4;strokeColor=#276749;strokeWidth=1.5;fontColor=#276749;fontStyle=1;fontSize=11;verticalAlign=top;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="18" y="124" width="270" height="704" as="geometry"/></mxCell>
    <!-- DBTaskQueue panel -->
    <mxCell id="4" value="DBTaskQueue&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;주문 대기열 — 순서 보장&lt;/font&gt;" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#FFFAF0;strokeColor=#ED8936;strokeWidth=1.5;fontColor=#ED8936;fontStyle=1;fontSize=11;verticalAlign=top;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="304" y="124" width="320" height="704" as="geometry"/></mxCell>
    <!-- IDatabase Layer panel -->
    <mxCell id="5" value="IDatabase Layer&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;조리 방식 추상화&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#EBF5FF;strokeColor=#2E6DA4;strokeWidth=1.5;fontColor=#2E6DA4;fontStyle=1;fontSize=11;verticalAlign=top;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="640" y="124" width="602" height="704" as="geometry"/></mxCell>
    <!-- Session event boxes (shifted down 72) -->
    <mxCell id="6" value="&lt;b&gt;&lt;font style=&quot;font-size:12px;&quot;&gt;OnConnected()&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;ClientSession&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;세션 접속 이벤트&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;fillColor=#276749;strokeColor=none;strokeWidth=0;fontColor=#FFFFFF;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="32" y="622" width="240" height="76" as="geometry"/></mxCell>
    <mxCell id="7" value="&lt;b&gt;&lt;font style=&quot;font-size:12px;&quot;&gt;OnDisconnected()&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;ClientSession&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;세션 해제 이벤트&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;fillColor=#276749;strokeColor=none;strokeWidth=0;fontColor=#FFFFFF;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="32" y="510" width="240" height="76" as="geometry"/></mxCell>
    <mxCell id="8" value="&lt;b&gt;&lt;font style=&quot;font-size:12px;&quot;&gt;OnRecv()&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;ClientSession&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;패킷 수신 처리&lt;/font&gt;" style="rounded=1;arcSize=24;whiteSpace=wrap;html=1;fillColor=#2C7A7B;strokeColor=none;strokeWidth=0;fontColor=#FFFFFF;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="32" y="390" width="240" height="76" as="geometry"/></mxCell>
    <mxCell id="9" value="&lt;b&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;기타 이벤트 (확장 가능)&lt;/font&gt;&lt;/b&gt;" style="rounded=1;arcSize=24;whiteSpace=wrap;html=1;fillColor=#EDF2F7;strokeColor=#718096;strokeWidth=1;fontColor=#718096;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="64" y="254" width="240" height="58" as="geometry"/></mxCell>
    <!-- Arrow label text -->
    <mxCell id="10" value="AsyncRecordConnectTime()" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#718096;fontSize=8;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="152" y="596" width="240" height="20" as="geometry"/></mxCell>
    <mxCell id="11" value="AsyncRecordDisconnectTime()" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#718096;fontSize=8;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="152" y="486" width="240" height="20" as="geometry"/></mxCell>
    <mxCell id="12" value="DB 작업 enqueue (필요 시)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#718096;fontSize=8;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="152" y="366" width="240" height="20" as="geometry"/></mxCell>
    <!-- DBTaskQueue internal boxes (shifted) -->
    <mxCell id="13" value="&lt;b&gt;&lt;font style=&quot;font-size:13px;&quot;&gt;DBTaskQueue&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;Async enqueue — 즉시 리턴&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;워커 1개  (순서 보장)&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px;color:#A0AEC0;&quot;&gt;주문 대기열&lt;/font&gt;" style="rounded=1;arcSize=11;whiteSpace=wrap;html=1;fillColor=#ED8936;strokeColor=none;strokeWidth=0;fontColor=#FFFFFF;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="318" y="586" width="290" height="138" as="geometry"/></mxCell>
    <!-- C-Style: WAL narrative callout -->
    <mxCell id="14" value="&lt;b&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;WAL  (Write-Ahead Log)&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;P|seq|data  →  &quot;이 작업 처리 예정&quot; 기록&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;D|seq  →  &quot;완료&quot; 체크&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;서버 꺼짐 → 재시작 시 P만 있고 D 없는 항목 자동 재처리&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;영수증 먼저 발행&lt;/font&gt;" style="rounded=1;arcSize=13;whiteSpace=wrap;html=1;fillColor=#FEFCE8;strokeColor=#D69E2E;strokeWidth=2;fontColor=#744210;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="318" y="430" width="290" height="130" as="geometry"/></mxCell>
    <mxCell id="15" value="&lt;b&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;DB Worker (Thread × 1)&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;FIFO 처리  ·  예외 핸들링&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;완료 후 WAL D|seq 기록&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;주방 — 순서대로 조리&lt;/font&gt;" style="rounded=1;arcSize=19;whiteSpace=wrap;html=1;fillColor=#DD6B20;strokeColor=none;strokeWidth=0;fontColor=#FFFFFF;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="318" y="334" width="290" height="82" as="geometry"/></mxCell>
    <mxCell id="16" value="&lt;b&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;Crash Recovery&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;서버 재시작 시 WAL + .bak 병합&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;미완료 작업만 재큐잉&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;미처리 주문 재발행&lt;/font&gt;" style="rounded=1;arcSize=19;whiteSpace=wrap;html=1;fillColor=#C05621;strokeColor=none;strokeWidth=0;fontColor=#FFFFFF;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="318" y="238" width="290" height="82" as="geometry"/></mxCell>
    <mxCell id="17" value="&lt;b&gt;&lt;font style=&quot;font-size:10.5px;&quot;&gt;Initialize(workerCount=1)&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;워커 수 강제 1개 (connect/disconnect 순서)&lt;/font&gt;" style="rounded=1;arcSize=22;whiteSpace=wrap;html=1;fillColor=#7B341E;strokeColor=none;strokeWidth=0;fontColor=#FFFFFF;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="318" y="152" width="290" height="62" as="geometry"/></mxCell>
    <!-- Factory pattern box (C-style callout) -->
    <mxCell id="18" value="&lt;b&gt;&lt;font style=&quot;font-size:12px;&quot;&gt;DatabaseFactory::CreateDatabase(type)&lt;/font&gt;&lt;/b&gt;" style="rounded=1;arcSize=23;whiteSpace=wrap;html=1;fillColor=#E9D8FD;strokeColor=#B794F4;strokeWidth=1.5;fontColor=#553C9A;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="658" y="676" width="570" height="52" as="geometry"/></mxCell>
    <!-- C-Style: DatabaseFactory pattern callout -->
    <mxCell id="c_db_factory" value="&lt;b&gt;DatabaseFactory 패턴:&lt;/b&gt;&lt;br/&gt;테스트 환경 → MockDatabase (DB 없이 로그만 출력)&lt;br/&gt;개발 환경 → SQLiteDatabase (파일 하나로 동작)&lt;br/&gt;운영 환경 → ODBCDatabase (MS SQL / Oracle 연결)&lt;br/&gt;코드 변경 없이 설정만 바꾸면 됩니다" style="shape=callout;whiteSpace=wrap;html=1;fillColor=#E9D8FD;strokeColor=#B794F4;strokeWidth=2;fontSize=10;fontColor=#553C9A;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="658" y="740" width="570" height="80" as="geometry"/></mxCell>
    <mxCell id="19" value="&lt;&lt;factory&gt;&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#553C9A;fontSize=11;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="720" y="666" width="200" height="18" as="geometry"/></mxCell>
    <!-- IDatabase interface box -->
    <mxCell id="20" value="&lt;b&gt;&lt;font style=&quot;font-size:12px;&quot;&gt;&lt;&lt;interface&gt;&gt;  IDatabase  /  IStatement&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Execute()  ·  Query()  ·  Prepare()&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;BeginTransaction()  ·  Commit()  ·  Rollback()&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;조리법 계약 — 방식은 달라도 결과는 동일&lt;/font&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#EBF5FF;strokeColor=#2E6DA4;strokeWidth=2.5;fontColor=#1E3A5C;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="720" y="554" width="430" height="104" as="geometry"/></mxCell>
    <!-- Database impl boxes -->
    <mxCell id="21" value="&lt;b&gt;&lt;font style=&quot;font-size:12px;&quot;&gt;MockDatabase&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;테스트 / 개발용&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;DB 없이 동작&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;로그만 출력&lt;/font&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#4299E1;strokeColor=none;strokeWidth=0;fontColor=#FFFFFF;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="652" y="152" width="180" height="160" as="geometry"/></mxCell>
    <mxCell id="22" value="&lt;b&gt;&lt;font style=&quot;font-size:12px;&quot;&gt;SQLiteDatabase&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;파일 기반 경량 DB&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;SessionLog 저장&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#A0AEC0;&quot;&gt;Linux / Windows&lt;/font&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#276749;strokeColor=none;strokeWidth=0;fontColor=#FFFFFF;fontStyle=0;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="858" y="152" width="180" height="160" as="geometry"/></mxCell>
