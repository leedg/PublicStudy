    <!-- Summary box -->
    <mxCell id="c_db_summary" value="✅ 핵심 포인트: DB 작업을 큐에 넣고 즉시 리턴(논블로킹). 서버가 꺼져도 WAL 덕분에 데이터는 살아있습니다." style="rounded=1;arcSize=5;whiteSpace=wrap;html=1;fillColor=#F0FFF4;strokeColor=#68D391;strokeWidth=2;fontColor=#276749;fontStyle=1;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="18" y="840" width="1224" height="44" as="geometry"/></mxCell>
