flowchart LR
    classDef io     fill:#E3F2FD,color:#0D47A1,stroke:#1565C0
    classDef hash   fill:#1A237E,color:#fff,stroke:#1A237E,font-weight:bold
    classDef worker fill:#E8F5E9,color:#1B5E20,stroke:#2E7D32

    subgraph IO["I/O мҷ„лЈҢ мқҙлІӨнҠё (IOCP / epoll / io_uring)"]
        A["Session A\nrecv мҷ„лЈҢ"]:::io
        B["Session B\nrecv мҷ„лЈҢ"]:::io
        C["Session C\nrecv мҷ„лЈҢ"]:::io
    end

    H["workerIndex\n= sessionId % N\n(shared_lock ліҙнҳё)"]:::hash

    subgraph W["лЎңм§Ғ мӣҢм»Ө н’Җ (KeyedDispatcher)"]
        W0["Worker 0\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nSession A нҢЁнӮ· мІҳлҰ¬\nSession C нҢЁнӮ· мІҳлҰ¬\nмҲңм„ң ліҙмһҘ(FIFO)"]:::worker
        W1["Worker 1\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nSession B нҢЁнӮ· мІҳлҰ¬\nмҲңм„ң ліҙмһҘ(FIFO)"]:::worker
        W2["Worker 2\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n..."]:::worker
    end

    NOTE["лҸҷмқј sessionId вҶ’ н•ӯмғҒ лҸҷмқј мӣҢм»Ө\nвҶ’ м„ём…ҳлі„ мІҳлҰ¬ мҲңм„ң ліҙмһҘ\nвҶ’ mRecvMutex л¶Ҳн•„мҡ”"]

    A -->|"key = A"| H
    B -->|"key = B"| H
    C -->|"key = C"| H
    H -->|"idx = 0"| W0
    H -->|"idx = 1"| W1
