flowchart TD
    Caller["호출자\n(IOCP 완료 스레드 / 게임 로직)"]

    subgraph KD["KeyedDispatcher"]
        Dispatch["Dispatch(key, task)\nshared_lock(mWorkersMutex)\nworkerIndex = key % N"]
    end

    subgraph Workers["워커 풀 (N개)"]
        W0["Worker 0\nExecutionQueue\n(BackpressurePolicy)"]
        W1["Worker 1\nExecutionQueue\n(BackpressurePolicy)"]
        WN["Worker N-1\nExecutionQueue\n(BackpressurePolicy)"]
    end

    subgraph Threads["워커 스레드 (N개)"]
        T0["스레드 0\nWorkerThreadFunc\nPop → task()"]
        T1["스레드 1\nWorkerThreadFunc\nPop → task()"]
        TN["스레드 N-1\nWorkerThreadFunc\nPop → task()"]
    end

    Upper1["DBTaskQueue\n(TestServer)\nsessionId % workerCount"]
    Upper2["OrderedTaskQueue\n(DBServer)\nserverId % workerCount"]
    AS["AsyncScope\nmInFlight 추적\nCancel / WaitForDrain"]
    TQ["TimerQueue\nmin-heap\nScheduleOnce / ScheduleRepeat"]

    Caller -->|"key 기반 라우팅"| Dispatch
    Upper1 -->|"자체 워커 배열\n(동일 원칙)"| Workers
    Upper2 -->|"KeyedDispatcher 위임"| Dispatch

    Dispatch -->|"key % N == 0"| W0
    Dispatch -->|"key % N == 1"| W1
    Dispatch -->|"key % N == N-1"| WN

    W0 -->|"단일 스레드 소비\nFIFO 보장"| T0
    W1 -->|"단일 스레드 소비\nFIFO 보장"| T1
    WN -->|"단일 스레드 소비\nFIFO 보장"| TN

    AS -.->|"Submit 래핑\nBeginTask/EndTask"| Dispatch
    TQ -.->|"만료 콜백 실행\n(워커 스레드)"| T0

    note1["동일 key → 동일 워커 → per-key FIFO\n세션 단위 DB 작업 순서 보장"]
